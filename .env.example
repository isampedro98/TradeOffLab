POSTGRES_DB=tradeofflab
POSTGRES_USER=tradeofflab
POSTGRES_PASSWORD=tradeofflab
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://tradeofflab:tradeofflab@db:5432/tradeofflab

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

LITELLM_PROXY_PORT=4000
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MODEL=tradeofflab-default
LITELLM_MASTER_KEY=tradeofflab-dev-key
LITELLM_API_KEY=tradeofflab-dev-key
LITELLM_TIMEOUT_SECONDS=180
LITELLM_RESPONSE_FORMAT_STRATEGY=json_schema
GEMINI_API_KEY=replace-me

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_LITELLM_MODEL=ollama/qwen3:8b
OLLAMA_IMAGE=ollama/ollama:latest
# If you run Ollama natively on the host, point LiteLLM there instead:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

WEB_RESEARCH_SEARCH_PROVIDER=duckduckgo_html
WEB_RESEARCH_TIMEOUT_SECONDS=20
WEB_RESEARCH_USER_AGENT=TradeOffLabBot/0.1
